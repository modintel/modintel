{
	order coraza_waf first
}

:8080 {
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy no-referrer
		Permissions-Policy geolocation=(), microphone=(), camera=()
	}

	coraza_waf {
		include /opt/coraza/config/coraza.conf
		include /opt/coraza/config.d/user.conf
		include /opt/coraza/config/crs-setup.conf
		include /opt/coraza/owasp-crs/rules/*.conf
		include /opt/coraza/config.d/custom.conf
		include /opt/coraza/rules/*.conf
		include /opt/coraza/rules.d/*.conf
		include /opt/coraza/overrides/*.conf
	}

	reverse_proxy juice-shop:3000 {
		trusted_proxies private_ranges
	}
}

:3000 {
	root * /srv/dashboard
	encode zstd gzip

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy geolocation=(), microphone=(), camera=()
		Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' http: https:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
	}

	handle /api/v1/auth/* {
		reverse_proxy auth-service:8084
	}

	handle /api/v1/users* {
		reverse_proxy auth-service:8084
	}

	handle /api/health/review-api {
		rewrite * /health
		reverse_proxy review-api:8082
	}

	handle /api/health/log-collector {
		rewrite * /health
		reverse_proxy log-collector:8081
	}

	handle /api/health/inference-engine {
		rewrite * /health
		reverse_proxy inference-engine:8083
	}

	handle /api/health/auth-service {
		rewrite * /health
		reverse_proxy auth-service:8084
	}

	handle /api/health/aggregate {
		rewrite * /aggregate/health
		reverse_proxy health-aggregator:8090
	}

	handle /api/health/aggregate/detailed {
		rewrite * /aggregate/health/detailed
		reverse_proxy health-aggregator:8090
	}

	handle /api/health/proxy-waf {
		header Content-Type application/json
		respond "{\"status\":\"ok\",\"service\":\"proxy-waf\"}" 200
	}

	handle /api/* {
		reverse_proxy review-api:8082
	}

	handle_path /inference/* {
		reverse_proxy inference-engine:8083
	}

	redir /signin.html /signin 308
	redir /index.html /events 308
	redir /rules.html /rules 308
	redir /training.html /training 308
	redir /datasets.html /datasets 308
	redir /reports.html /reports 308
	redir /monitor.html /monitor 308
	redir /Monitor.html /monitor 308
	redir /settings.html /settings 308
	redir /help.html /help 308

	@signin path /signin
	rewrite @signin /signin.html

	@events path / /events
	rewrite @events /index.html

	@rules path /rules
	rewrite @rules /rules.html

	@training path /training
	rewrite @training /training.html

	@datasets path /datasets
	rewrite @datasets /datasets.html

	@reports path /reports
	rewrite @reports /reports.html

	@monitor path /monitor
	rewrite @monitor /monitor.html

	@settings path /settings
	rewrite @settings /settings.html

	@help path /help
	rewrite @help /help.html

	file_server
}
